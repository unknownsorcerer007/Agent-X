{
  "_comment": "Agent-X MCP Config — NO API KEY NEEDED",
  "mcpServers": {
    "agent-x": {
      "command": "python3",
      "args": ["/absolute/path/to/Agent-X/connectors/mcp_passthrough.py"],
      "env": {
        "AGENT_X_URL": "http://localhost:8001",
        "AGENT_X_TOKEN": "your-agent-token-here",
        "AGENT_X_COMPRESS": "aggressive",
        "AGENT_X_MAX_OUTPUT": "8000"
      }
    }
  },
  "_env_options": {
    "AGENT_X_COMPRESS": "aggressive | normal | off (default: aggressive)",
    "AGENT_X_MAX_OUTPUT": "max chars per tool result (default: 8000)"
  },
  "_setup": [
    "1. Start Agent-X server: python main.py --agent-token 'your-token'",
    "2. Replace /absolute/path/to with real path",
    "3. Use same token in AGENT_X_TOKEN",
    "4. Restart Claude Desktop"
  ]
}
