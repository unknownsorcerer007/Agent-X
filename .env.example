# Agent-OS Environment Variables
# Copy this file to .env and fill in your values.
# ALL keys are optional — Agent-OS runs fully self-contained without any of these.

# ─── Authentication ─────────────────────────────────────────
JWT_SECRET_KEY=
AGENT_TOKEN=

# ─── Database (PostgreSQL) ─────────────────────────────────
DATABASE_DSN=postgresql+asyncpg://agent_os:password@localhost:5432/agent_os

# ─── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Optional: LLM Provider ────────────────────────────────
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GOOGLE_API_KEY=...
# GROQ_API_KEY=gsk_...

# ─── Optional: CAPTCHA Solving ─────────────────────────────
# CAPTCHA_API_KEY=your-key

# ─── Optional: Proxy ───────────────────────────────────────
# PROXY_URL=http://user:pass@proxy:port
