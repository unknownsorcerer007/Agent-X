# ═══════════════════════════════════════════════════════════════════════════════
# Agent X — Comprehensive .gitignore
# Based on github/gitignore templates for Python, Node, and project-specific items
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Project-Specific ────────────────────────────────────────────────────────
.env
.env.local
.env.*.local
.agent-x/
*.enc
*.key
*.pem
credentials.json
cloudflare_tunnel.err

# ─── Build / Distribution ────────────────────────────────────────────────────
dist/
build/
out/
*.egg-info/
*.egg
*.whl
*.spec

# ─── Python ──────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
.venv/
env/
ENV/
pythonenv*
.eggs/
*.egg-info/
lib/
lib64/
parts/
sdist/
wheels/

# ─── Pytest / Coverage ───────────────────────────────────────────────────────
.coverage
.pytest_cache/
htmlcov/
.tox/
.nox/
.hypothesis/

# ─── Node / TypeScript ───────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
bun.lockb
.pnpm-debug.log*

# ─── IDE / Editor ────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~
.project
.classpath
.settings/
*.sublime-workspace
*.sublime-project

# ─── OS ──────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# ─── Logs / Runtime Data ─────────────────────────────────────────────────────
*.log
logs/
tmp/
temp/
*.pid
*.pid.lock
*.sqlite
*.sqlite3
*.db

# ─── Browser / Session Data ──────────────────────────────────────────────────
~/.agent-x/
browser-states/
chrome-profile/
cookies/
downloads/
screenshots/

# ─── Test Results ────────────────────────────────────────────────────────────
*results*.json
*report.json
stress_test_*.json
brutal_test_*.json
production_test_*.json
grind_results_*.json

# ─── Legacy / Migration ──────────────────────────────────────────────────────
mingit/
mingit.zip
push_to_github.ps1
